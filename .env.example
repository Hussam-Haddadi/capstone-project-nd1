# Copy to ".env" in this repo root (same folder as this file). Used by nidd_api when you run uvicorn.

# --- Optional: ML model path ---
# NIDD_MODEL_PATH=

# --- CORS (comma-separated origins) ---
# NIDD_CORS_ORIGINS=*

# --- Twilio relay (SMS → defense → WhatsApp sandbox) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# SMS number people text (E.164, e.g. +966...)
# TWILIO_SMS_NUMBER=
# WhatsApp *sender* must be Twilio's WhatsApp-enabled number (Sandbox shows e.g. +14155238886).
# Not the same as SMS unless that number is WhatsApp-enabled on Twilio. Format: +E164 or whatsapp:+E164
# TWILIO_WHATSAPP_FROM=
# Your phone joined to sandbox (E.164), e.g. whatsapp:+966...
# TARGET_WHATSAPP_NUMBER=
# Webhook URL base for signature validation (ngrok / production), no trailing slash
# PUBLIC_BASE_URL=
# Local/dev: set true if webhook URL and PUBLIC_BASE_URL mismatch causes empty UI
# TWILIO_SKIP_SIGNATURE_VALIDATION=true
